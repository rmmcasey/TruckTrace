# Supabase project API URL — found in Supabase Dashboard > Settings > API
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase service role key — found in Supabase Dashboard > Settings > API
# WARNING: Never expose this key client-side. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# OpenCage reverse geocoding API key — https://opencagedata.com
OPENCAGE_API_KEY=

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Power Automate sync shared secret — generate with: openssl rand -hex 32
# Must match the x-sync-secret header value configured in your Power Automate HTTP action
SYNC_SECRET=

# Upstash Redis — required for PIN rate limiting on /api/location and /api/journey/complete
# Create a free Redis database at https://console.upstash.com
# Leave blank to disable rate limiting (not recommended in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend email API key — https://resend.com
# Required for signup notifications, approval/rejection emails, and password reset emails.
# Leave blank to silently skip all outbound emails (auth still works without it).
RESEND_API_KEY=

# Admin dashboard credentials
# ADMIN_EMAIL: the email address where new signup notifications are sent
# ADMIN_PASSWORD: bcrypt hash of the admin dashboard password
# Generate with: node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
ADMIN_EMAIL=
ADMIN_PASSWORD=

# The manager_accounts UUID that owns trucks synced via Power Automate
# Get this from the manager_accounts table after the dealer signs up and is approved
SYNC_MANAGER_ID=
